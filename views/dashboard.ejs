<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-slate-950 flex items-center justify-center overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-blue-600 blur-3xl rounded-full opacity-20"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-600 blur-3xl rounded-full opacity-20"></div>
    <div class="relative bg-slate-900/70 backdrop-blur-xl border border-slate-700 rounded-3xl p-10 w-11/12 max-w-xl shadow-2xl">
        <div class="text-center">
            <div class="text-7xl mb-4">
                🎉
            </div>
            <h1 class="text-4xl font-bold text-white">
                Login Successful
            </h1>
            <p class="text-green-400 mt-3">
                Welcome back!
            </p>
        </div>
        <div class="mt-10 space-y-5">
            <div class="bg-slate-800 rounded-xl p-4">
                <p class="text-gray-400">
                    Username
                </p>
                <h2 class="text-white text-xl font-semibold">
                    <%= user.username %>
                </h2>
            </div>
            <div class="bg-slate-800 rounded-xl p-4">
                <p class="text-gray-400">
                    Email
                </p>
                <h2 class="text-white text-xl font-semibold">
                    <%= user.email %>
                </h2>
            </div>
            <div class="bg-slate-800 rounded-xl p-4">
                <p class="text-gray-400">
                    Age
                </p>
                <h2 class="text-white text-xl font-semibold">
                    <%= user.age %>
                </h2>
            </div>
        </div>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/logout"
                class="flex-1 text-center bg-red-600 hover:bg-red-500 py-3 rounded-xl text-white font-semibold transition duration-300 shadow-lg">
                Logout
            </a>
            <form action="/delete-account" method="POST" class="flex-1"
                onsubmit="return confirm('Are you sure you want to permanently delete your account? This action cannot be undone.');">
                <button
                    type="submit"
                    class="w-full bg-slate-700 hover:bg-red-700 py-3 rounded-xl text-white font-semibold transition duration-300 shadow-lg cursor-pointer">
                    🗑 Delete Account
                </button>
            </form>
        </div>
    </div>
</body>
</html>