<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Failed</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-slate-950 flex items-center justify-center">
    <div class="absolute top-0 left-0 w-96 h-96 bg-red-600 blur-3xl rounded-full opacity-20"></div>
    <div class="bg-slate-900/70 backdrop-blur-xl border border-red-500 rounded-3xl p-10 w-11/12 max-w-md text-center shadow-2xl">
        <div class="text-7xl mb-5">
            ❌
        </div>
        <h1 class="text-4xl text-white font-bold">
            Login Failed
        </h1>
        <p class="text-gray-400 mt-4">
            Invalid email or password.
        </p>
        <a href="/login"
            class="inline-block mt-8 bg-red-600 hover:bg-red-500 px-6 py-3 rounded-xl text-white font-semibold transition">
            Try Again
        </a>
    </div>
</body>
</html>