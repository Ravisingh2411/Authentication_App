<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-slate-950 flex items-center justify-center overflow-hidden">

    <div class="absolute top-0 left-0 w-96 h-96 bg-blue-600 rounded-full blur-3xl opacity-20"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-600 rounded-full blur-3xl opacity-20"></div>

    <div class="relative z-10 w-11/12 max-w-6xl">

        <div class="text-center mb-14">
            <h1 class="text-5xl md:text-6xl font-bold text-white">
                Welcome 👋
            </h1>

            <p class="text-gray-400 mt-5 text-lg max-w-2xl mx-auto">
                Register if you're a new user or login to continue your journey.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-10">

            <div class="bg-slate-900/70 backdrop-blur-lg border border-slate-700 rounded-3xl p-10 shadow-xl transition-all duration-300 hover:border-blue-500 hover:shadow-blue-500/20 hover:-translate-y-2">

                <div class="text-6xl mb-6">
                    🚀
                </div>

                <h2 class="text-3xl font-bold text-white mb-4">
                    Register
                </h2>

                <p class="text-gray-400 leading-7 mb-8">
                    First time here? Create your account and get access to all features.
                </p>

                <a href="/register"
                    class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-semibold px-7 py-3 rounded-xl transition duration-300">
                    Create Account
                </a>

            </div>

            <div class="bg-slate-900/70 backdrop-blur-lg border border-slate-700 rounded-3xl p-10 shadow-xl transition-all duration-300 hover:border-purple-500 hover:shadow-purple-500/20 hover:-translate-y-2">

                <div class="text-6xl mb-6">
                    🔐
                </div>

                <h2 class="text-3xl font-bold text-white mb-4">
                    Login
                </h2>

                <p class="text-gray-400 leading-7 mb-8">
                    Already have an account? Login securely and continue where you left off.
                </p>

                <a href="/login"
                    class="inline-block bg-purple-600 hover:bg-purple-500 text-white font-semibold px-7 py-3 rounded-xl transition duration-300">
                    Sign In
                </a>

            </div>

        </div>

        <div class="mt-16 text-center text-gray-500">
            Secure Authentication • Fast Access • Modern Experience
        </div>

    </div>

</body>
</html>